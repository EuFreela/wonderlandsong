{
  "name": "wonderlandsong2",
  "private": true,
  "version": "0.8.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "lighthouse:serve": "npm run build && vite preview --host 127.0.0.1 --port 4173",
    "lighthouse:mobile": "lighthouse http://127.0.0.1:4173/ --only-categories=performance --only-categories=accessibility --only-categories=best-practices --only-categories=seo --form-factor=mobile --screenEmulation.mobile=true --chrome-flags=\"--headless --no-sandbox --disable-gpu\" --quiet --output=json --output-path=./lighthouse-mobile.json",
    "lighthouse:desktop": "lighthouse http://127.0.0.1:4173/ --only-categories=performance --only-categories=accessibility --only-categories=best-practices --only-categories=seo --preset=desktop --chrome-flags=\"--headless --no-sandbox --disable-gpu\" --quiet --output=json --output-path=./lighthouse-desktop.json",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc -b",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.1",
    "react-router-dom": "^6.21.1",
    "zod": "^3.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^15.0.0",
    "jsdom": "^25.0.0",
    "lighthouse": "^12.8.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.9"
  }
}
